# ExchangeRate-API key (get free key at https://www.exchangerate-api.com/)
FX_API_KEY=your_api_key_here

# RevenueCat public SDK key (get from RevenueCat dashboard > API Keys)
REVENUECAT_API_KEY=your_revenuecat_rcb_key_here

# RevenueCat Web Purchase Link ID (from dashboard > Web section)
WEB_PURCHASE_LINK_ID=your_web_purchase_link_id_here
