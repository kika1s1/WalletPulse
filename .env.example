# -----------------------------------------------------------------------------
# WalletPulse environment
# -----------------------------------------------------------------------------
# Copy this file to `.env` (project root) and also to `android/app/.env` so that
# `react-native-config` can see it at Android build time. Do NOT commit the
# resulting `.env` files.
# -----------------------------------------------------------------------------

# --- Currency conversion (required) ------------------------------------------
# Free API key from https://www.exchangerate-api.com/
FX_API_KEY=your_exchangerate_api_key

# --- Supabase (required) -----------------------------------------------------
# Project settings -> API in the Supabase dashboard. Use the ANON / PUBLIC key
# (never the service_role key) because this value ships inside the mobile app.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# --- SMTP (optional, used by backend / edge functions, not the mobile app) ---
# Leave unset if you're only running the app on-device.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_app_password
EMAIL_FROM=WalletPulse <your_email@example.com>
